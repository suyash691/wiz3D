  <!-- After Release builds, mirror nvapi[64].dll into the dx10-11 release
       folder. NvApiProxy ships alongside the DX10/11 main build (DX9 already
       lives at $(OutDir)). NOT mirrored to opengl-quad-buffer-stereo: the OGL
       wrapper never touches NvAPI. deploy_to_releases.ps1 handles the
       3d-vision-direct/* leaves separately, because those leaves don't
       always exist before this project builds. -->
  <Target Name="MirrorNvApiToOtherReleaseFolders" AfterTargets="Build"
          Condition="'$(Configuration)'=='Release'">
    <PropertyGroup>
      <_NvApiArchDir Condition="'$(Platform)'=='Win32'">x86</_NvApiArchDir>
      <_NvApiArchDir Condition="'$(Platform)'=='x64'">x64</_NvApiArchDir>
      <_NvApiReleaseRoot>$(MSBuildProjectDirectory)\..\releases\wiz3D</_NvApiReleaseRoot>
    </PropertyGroup>
    <MakeDir Directories="$(_NvApiReleaseRoot)\dx10-11\$(_NvApiArchDir)" />
    <Copy SourceFiles="$(TargetPath)"
          DestinationFolder="$(_NvApiReleaseRoot)\dx10-11\$(_NvApiArchDir)"
          SkipUnchangedFiles="true" />
  </Target>
