<?xml version="1.0" encoding="utf-8" ?>
<!--
=============================================================================
  wiz3D Configuration File (Config.xml)
=============================================================================
  Drop this file next to the DLLs in the game folder. Edit with any text
  editor to change stereo 3D settings. Changes take effect on next game launch.

  KEYBOARD SHORTCUTS (active while game is running):
  ═══════════════════════════════════════════════════
	Numpad *          Toggle stereo 3D on/off
	Numpad +          Increase separation (stereo depth)
	Numpad -          Decrease separation (stereo depth)
	Shift+Numpad +    Increase convergence (screen depth / ZPS)
	Shift+Numpad -    Decrease convergence (screen depth / ZPS)
	Numpad /          Toggle auto-focus
	Numpad 7/8/9      Switch between 3 saved presets
	Ctrl+F8           Swap left/right eyes
	Shift+Numpad *    Open on-screen wizard overlay
	Shift+F1          Toggle hotkey OSD (shows key hints)
	Ctrl+Numpad /     Toggle laser sight (crosshair at screen depth)
	PrintScreen       Take stereo screenshot (saves to My Pictures\wiz3D Screenshots\)

  KEY CODE FORMAT: Key="code" where code = (modifier << 8) | VK_code
	Modifiers: Shift=0x100, Ctrl=0x200, Alt=0x400, Win=0x800
	Examples:  106 = Numpad*  |  363 = Shift(0x100) + Numpad+(0x6B)
	Set Key="0" to disable a hotkey.
=============================================================================
-->
<Config Version="1" xmlns="http://schemas.iz3d.com/config/2007">

	<!-- ═══════════════ GLOBAL SETTINGS ═══════════════════════════════
		 These apply to the driver as a whole, not per-game.
		 ═══════════════════════════════════════════════════════════════ -->
	<GlobalSettings>
		<!-- Hook DX9 games on startup: 1=yes 0=no -->
		<RunAtStartup Value="1"/>
		<!-- Hook OpenGL games on startup: 1=yes 0=no -->
		<OGLRunAtStartup Value="0"/>

		<!-- OUTPUT MODE — which stereo display method to use.
			 Set this to the DLL name (without .dll) from the OutputMethods/ folder.
			 Options:
			   "SideBySideOutput"     — Side-by-side (VR headsets, 3D TVs, passive monitors)
			   "AnaglyphOutput"       — Red/cyan anaglyph glasses
			   "InterlacedOutput"     — Row-interlaced (passive 3D monitors like Zalman)
			   "S3DOutput"            — iZ3D monitor native dual-panel output
			   "S3DMarkedOutput"      — Debug: marks left/right with visual indicators
			   "ShutterOutput"        — Page-flip shutter glasses (generic)
			   "S3DShutterOutput"     — iZ3D shutter glasses
			   "iZShutterOutput"      — iZ3D shutter (alternate driver)
			   "CMOShutterOutput"     — CMO brand shutter glasses
			   "DualProjectionOutput" — Dual projector setups
			   "DLP3DOutput"          — DLP Link 3D projectors
			   "ATIDLP3DOutput"       — ATI DLP 3D
			   "AMDHD3DOutput"        — AMD HD3D
			   "StereoMirrorOutput"   — Mirror left/right views
			   "S3D120HzProjectorsOutput" — 120Hz projector output
			   "VR920Output"          — Vuzix VR920 headset
			   "Z800Output"           — eMagin Z800 headset
			   "LenovoOutput"         — Lenovo 3D display
			   "ZalmanOutput"         — Zalman Trimon monitors
			   "TaerimOutput"         — Taerim display
			   "AvitridOutput"        — Avitrid display
			   "SimulatedRealityWeaveOutput" — Leia / Samsung Odyssey 3D / Acer SpatialLabs (Moving Lightfield displays)
		-->
		<OutputMethodDll Value="SideBySideOutput"/>

		<!-- Output sub-mode (meaning depends on the output plugin, usually 0) -->
		<OutputMode Value="0"/>
		<!-- Span mode: 0=single monitor, 1=span across monitors -->
		<OutputSpanMode Value="0"/>
		<!-- Display scaling: 0=none, 1=scale to native res -->
		<DisplayScalingMode Value="0"/>
		<!-- Native resolution override (0=auto-detect) -->
		<DisplayNativeWidth Value="0"/>
		<DisplayNativeHeight Value="0"/>

		<!-- Shutter mode (for shutter-glass outputs only):
			 -1=auto, 0=simple, 1=multi-threaded, 2=multi-device,
			  3=ATI quad-buffer, 4=UM hook D3D9, 5=UM hook D3D9Ex -->
		<ShutterMode Value="-1"/>
		<!-- Shutter glasses refresh rate override (0=auto) -->
		<ShutterRefreshRate Value="0"/>

		<!-- Extract depth buffer for depth-based effects: 0=off 1=on -->
		<ExtractDepthBuffer Value="0"/>
		<!-- Show mono (non-stereo) image on second monitor: 0=off 1=on -->
		<DrawMonoImageOnSecondMonitor Value="0"/>
		<!-- Use mono device wrapper (disables stereo, keeps hooks): 0=off 1=on -->
		<UseMonoDeviceWrapper Value="0"/>
		<!-- Option B (Stage 2): COM-vtable wrapper for ID3D11Device + ID3D11DeviceContext.
		     When 1, the legacy DDI hooks (OpenAdapter10/_2 -> HookDeviceFuncs) are SKIPPED
		     and the d3d11.dll proxy wraps the device at the COM layer instead. Bypasses the
		     Win11 D3D11.10 DDI mismatch that broke the original iZ3D hook path. Set to 0
		     to roll back to the legacy DDI hook path for comparison. -->
		<UseCOMWrap Value="1"/>
		<!-- Option B: swap-chain wrap + Present hook. Required for stereo output —
		     without it the SBS composite (Stage 4d) never runs. Default ON now that
		     Stage 4d has shipped. Flip to 0 only to diagnose swap-chain wrap
		     regressions on specific games. -->
		<UseCOMWrapSwapChain Value="1"/>
		<!-- Option B: right-eye replay sweep at Present. Required for stereo output —
		     without it the right-eye sibling textures never get populated, so the
		     SBS composite shows the same image on both halves. Default ON now that
		     Stage 4c (per-eye CB math) and 4e (shader analyzer) have shipped. -->
		<UseCOMWrapReplay Value="1"/>
		<!-- Write debug info to log files: 0=off 1=on -->
		<CollectDebugInformation Value="0"/>
		<!-- Screenshot format: 0=BMP, 1=JPG, 2=PNG -->
		<ScreenshotType Value="0"/>
		<!-- Lock cursor to window in fullscreen: 1=yes 0=no -->
		<LockCursor Value="1"/>
		<!-- Workaround for Vista SP1 device reset crash: 0=off 1=on -->
		<FixVistaSP1ResetBug Value="0"/>
		<!-- Disable gamma correction: 0=normal 1=disable -->
		<DisableGammaApplying Value="0"/>
		<!-- UI language -->
		<Language Value="English"/>
	</GlobalSettings>

	<!-- ═══════════════ OUTPUT PLUGIN SETTINGS ════════════════════════
		 Per-output-plugin configuration. Only relevant if that output
		 plugin is selected above in OutputMethodDll.
		 ═══════════════════════════════════════════════════════════════ -->
	<Outputs>
		<!-- Anaglyph color matrices (for AnaglyphOutput).
			 Rows = RGB output channels, Cols = RGB input.
			 Default: optimized red/cyan. Edit for other color combos. -->
		<AnaglyphOutput>
			<CustomLeftMatrix
				m00="0" m01="0" m02="0"
				m10=".3333" m11=".3333" m12=".3333"
				m20="0" m21="0" m22="0"/>
			<CustomRightMatrix
				m00=".6667" m01=".3333" m02="0"
				m10="0" m11="0" m12="0"
				m20="0" m21=".3333" m22=".6667"/>
		</AnaglyphOutput>
		<!-- Side-by-side gap between left/right views (0-100 pixels) -->
		<SideBySideOutput>
			<Gap Value="0"/>
		</SideBySideOutput>
		<!-- Simulated Reality (Leia / Samsung Odyssey 3D / Acer SpatialLabs) weave settings.
			 sRGB: pairs both setInputViewTexture's isSRGB and setOutputSRGBWrite.
				 1 = sRGB pipeline (default — matches modern engines like Source / Unreal /
				     Unity that gamma-encode the backbuffer at present time)
				 0 = linear pipeline (use for older or HDR-linear games whose backbuffer
				     holds raw linear values; produces clipped/banded weave with the wrong setting) -->
		<SimulatedRealityWeaveOutput>
			<sRGB Value="1"/>
		</SimulatedRealityWeaveOutput>
	</Outputs>

	<!-- ═══════════════ GAME PROFILE (DEFAULT) ════════════════════════
		 These settings control stereo rendering behavior.
		 This is the default profile — applies to all games unless
		 overridden by a game-specific profile (not yet implemented).
		 ═══════════════════════════════════════════════════════════════ -->
	<DefaultProfile>

		<!-- ── Core Stereo Settings ────────────────────────────────── -->
		<!-- Router type: 0=hook via wrapper, 1=direct hook
			 Set to 0 for proxy DLL operation -->
		<RouterType Value="0"/>
		<!-- 0=normal hooking, 1=re-hook after device reset -->
		<RenewHookMode Value="0"/>
		<!-- Master stereo enable: 1=on 0=off (also toggled by Numpad*) -->
		<EnableStereo Value="1"/>
		<!-- Disable DX10 stereo wrapper: 0=allow 1=skip DX10 -->
		<DisableD3D10Driver Value="0"/>
		<!-- Alternate fullscreen state order for DXGI: 0=normal 1=alternate -->
		<AlternativeSetFullscreenStateOrder Value="0"/>

		<!-- ── On-Screen Display ───────────────────────────────────── -->
		<!-- Show FPS counter overlay: 1=yes 0=no -->
		<ShowFPS Value="1"/>
		<!-- Show on-screen display with stereo info: 1=yes 0=no -->
		<ShowOSD Value="1"/>

		<!-- ── Separation & Convergence ────────────────────────────── -->
		<!-- Separation mode: 0=normal (per-vertex), 1=alternate method -->
		<SeparationMode Value="0"/>
		<!-- Frustum adjustment: 0=shift (toe-in), 1=off-axis (correct) -->
		<FrustumAdjustMode Value="0"/>
		<!-- Black border width at screen edges (fraction, 0.0-0.1) -->
		<BlackAreaWidth Value="0.03"/>

		<!-- ── Performance Tuning ──────────────────────────────────── -->
		<!-- Presenter thread sleep time in ms (-2=auto, -1=off, 0-50=manual) -->
		<PresenterSleepTime Value="-2"/>
		<!-- Presenter flush time in ms (-1=auto, 0-50=manual) -->
		<PresenterFlushTime Value="-1"/>
		<!-- Max lag percent for presenter (1=default) -->
		<PresenterMaxLagPercent Value="1"/>
		<!-- Device mode: 0=auto, 1=force HAL, 2=force REF, 3=auto (preferred) -->
		<DeviceMode Value="3"/>
		<!-- Multi-window mode: 0=auto, 1=force single, 2=force multi -->
		<MultiWindowsMode Value="0"/>
		<!-- Force disable VSync: 0=no 1=yes (can improve framerate) -->
		<ForceVSyncOff Value="0"/>

		<!-- ── Render Target Management ────────────────────────────── -->
		<!-- Depth buffer extraction method: 0=auto -->
		<ModeObtainingDepthBuffer Value="0"/>
		<!-- Fullscreen-mode emulation: when 0 (legacy/iZ3D default) the wrapper forces every
		     fullscreen swap chain into windowed mode so it can install its own presenter
		     (required for shutter-glass outputs). For Simulated Reality / Side-By-Side /
		     Anaglyph that's unnecessary and produces sub-window rendering on DX10/11.
		     Default 1 (no emulation) — flip to 0 only when using a shutter output. -->
		<DisableFullscreenModeEmulation Value="1"/>
		<!-- Anti-aliasing: 1=enabled 0=disabled -->
		<EnableAA Value="1"/>
		<!-- Wide render target (double-width for stereo).
			 Per-vendor: 1=use wide RT, 0=use separate RTs -->
		<WideRenderTarget Value="1" Vendor="NVidia"/>
		<WideRenderTarget Value="0" Vendor="ATI"/>
		<WideRenderTarget Value="1" Vendor="Intel"/>
		<!-- Command buffering for multi-threaded rendering (per-vendor) -->
		<CommandBuffering Value="1" Vendor="ATI"/>
		<CommandBuffering Value="1" Vendor="NVidia"/>
		<RenderTargetBuffering Value="0"/>

		<!-- ── Render Target Stereo Flagging ──────────────────────────
			 How the wrapper decides which render targets get the L+R
			 stereo treatment vs. staying mono. Affects DX9 + DX10/11.
			 0 = never stereo (every RT mono; game renders flat regardless of StereoActive)
			 1 = always stereo (force L+R for every RT — most aggressive)
			 2 = heuristic (default; skips 1x1, square-if-MonoSquare, less-than-BB-if-MonoLessBB)
			 If a game has stereo plumbing alive but renders mono content,
			 try 1 first. If 1 causes crashes, the game needs per-target
			 tuning via the Mono Rendering Overrides below. -->
		<RenderTargetCreationMode Value="2"/>

		<!-- ── Mono Rendering Overrides ──────────────────────────────
			 Force specific resource types to render in mono (2D) instead
			 of stereo. Useful for fixing HUD, shadows, and UI elements
			 that look wrong in stereo. 0=stereo, 1=force mono -->
		<MonoRenderTargetTextures Value="0"/>
		<MonoRenderTargetSurfaces Value="0"/>
		<MonoDepthStencilTextures Value="0"/>
		<MonoDepthStencilSurfaces Value="0"/>

		<!-- ── Shader Modification ─────────────────────────────────── 
			 Controls how vertex shaders are modified for stereo.
			 These are advanced settings — change only if you understand
			 the stereo rendering pipeline. -->
		<!-- Force modify all vertex shaders (even non-3D ones): 0=auto 1=force -->
		<AlwaysModifyShaders Value="0"/>
		<!-- How separation is applied in vertex shaders: 0=auto -->
		<VSSeparationUpdateMode Value="0"/>
		<!-- Vertex shader modification method: 0=auto, 1=method A, 2=method B -->
		<VertexShaderModificationMethod Value="0"/>
		<!-- Modify shaders with incorrect projection matrices: 0=no 1=yes -->
		<ModifyIncorrectProjectionShaders Value="0"/>
		<!-- Always use default projection matrix for VS: 0=no 1=yes -->
		<AlwaysUseDefaultProjectionMatrixForVS Value="0"/>

		<!-- ── Render Target Mono/Stereo Heuristics ────────────────── 
			 Fine-grained control over which render targets are treated
			 as mono vs stereo based on size/shape. For fixing specific
			 visual artifacts (shadows, reflections, etc.) -->
		<CreateOneComponentRTInMono Value="0"/>
		<CreateSquareRTInMono Value="0"/>
		<CreateRTThatLessThanBBInMono Value="0"/>
		<CreateSquareDSInMono Value="0"/>
		<CreateDSThatLessThanBBInMono Value="0"/>
		<CreateBigSquareRTInStereo Value="0"/>
		<CreateBigSquareDSInStereo Value="0"/>
		<DisableNVCSTextureInWRTMode Value="0"/>
		<RenderToRightInMono Value="0"/>

		<!-- ── Game Compatibility ──────────────────────────────────── -->
		<!-- Game-specific workaround flags (bitmask, 0=none) -->
		<GameSpecific Value="0"/>
		<!-- Hide additional display adapters from the game: 0=no 1=yes -->
		<HideAdditionalAdapters Value="0"/>

		<!-- ── Fixed-Function Pipeline (Legacy DX7/8/9) ────────────── -->
		<!-- Render fixed-function (non-shader) geometry in mono: 0=stereo 1=mono -->
		<MonoFixedPipeline Value="0"/>
		<MonoFixedPipelineCheckingMethodIndex Value="0"/>
		<!-- Render draw-from-memory calls in mono: 0=stereo 1=mono -->
		<MonoDrawFromMemory Value="0"/>
		<!-- RHW (pre-transformed / 2D overlay) pipeline settings -->
		<MonoRHWPipeline Value="0"/>
		<MonoRHWCheckingMethodIndex Value="0"/>
		<!-- Render shaders without matrix detection in mono: 0=stereo 1=mono -->
		<RenderNonMatrixShadersInMono Value="0"/>
		<RenderIncorrectProjectionShadersInMono Value="0"/>
		<!-- RHW vertex modification method: 0=auto -->
		<RHWModificationMethod Value="0"/>

		<!-- ── Matrix Detection ─────────────────────────────────────── 
			 Controls how the driver detects projection matrices in shaders
			 to determine where to apply stereo separation. -->
		<UseSimpleStereoProjectionMethod Value="0"/>
		<SkipCheckOrthoMatrix Value="0"/>
		<CheckOnlyProjectionMatrix Value="0"/>
		<CheckExistenceInverseMatrix Value="0"/>
		<!-- Check for shadow projection matrices: 0=off 1=on -->
		<CheckShadowMatrix Value="0"/>
		<CheckInverseLR Value="0"/>
		<!-- Fix text position for non-16:9 aspect ratios: 0=off 1=on -->
		<FixNone16x9TextPosition Value="0"/>

		<!-- ── Stereo Strength Scaling ──────────────────────────────── -->
		<!-- Global separation multiplier (1.0=normal, 0.5=half, 2.0=double) -->
		<SeparationScale Value="1.0"/>
		<!-- Scale separation for small viewports (minimaps, etc.) -->
		<ScaleSeparationForSmallViewPorts Value="1.0"/>

		<!-- ── Auto-Focus Settings ─────────────────────────────────── 
			 Auto-focus adjusts convergence based on what's at screen center.
			 Toggle with Numpad / in-game. -->
		<SearchFrameSizeX Value="512"/>
		<SearchFrameSizeY Value="64"/>
		<!-- How fast auto-focus adjusts (1.0=normal) -->
		<ShiftSpeed Value="1"/>
		<!-- Maximum auto-focus range (0.0-1.0) -->
		<Max_ABS_rZPS Value="0.2"/>
		<!-- Y position for auto-focus sampling (0.0=top, 1.0=bottom) -->
		<FrameYCoordinate Value="0.495"/>

		<!-- ── Laser Sight (Crosshair) ─────────────────────────────── 
			 A crosshair rendered at screen depth — useful for aiming
			 in stereo 3D. Toggle with Ctrl+Numpad / in-game. -->
		<!-- Icon index: 0=default crosshair -->
		<LaserSightIconIndex Value="0"/>
		<!-- Custom icon path (leave empty for built-in) -->
		<CustomLaserSightIconPath Value=""/>
		<!-- Screen position (0.5, 0.5 = center) -->
		<LaserSightXCoordinate Value="0.5"/>
		<LaserSightYCoordinate Value="0.5"/>

		<!-- ── Miscellaneous ────────────────────────────────────────── -->
		<!-- Show the stereo wizard overlay on startup: 0=no 1=yes -->
		<ShowWizardAtStartup Value="0"/>
		<!-- Swap left/right eye views: 0=normal 1=swapped -->
		<SwapEyes Value="0"/>
		<!-- Enable laser sight crosshair: 0=off 1=on -->
		<LaserSightEnable Value="0"/>
		<!-- Don't lock mouse cursor: 0=lock 1=don't lock -->
		<DontLockMouse Value="0"/>

		<!-- ── Stereo Presets ───────────────────────────────────────── 
			 3 saveable presets for stereo separation & convergence.
			 Switch between them with Numpad 7/8/9 in-game.

			 One_div_ZPS = 1/ZPS (Zero Parallax Setting = convergence).
			   Higher = objects pushed further into screen. Range: 0.0 - 1.0
			 StereoBase = eye separation strength.
			   Higher = stronger 3D depth. Range: 0.0 - 0.8
			 AutoFocusEnable = auto-adjust convergence to center object.
			   0=manual, 1=auto
		-->
		<Presets>
			<Preset Index="0">
				<One_div_ZPS Value="0.1"/>
				<StereoBase Value="0.16"/>
				<AutoFocusEnable Value="0"/>
			</Preset>
			<Preset Index="1">
				<One_div_ZPS Value="0.1"/>
				<StereoBase Value="0.16"/>
				<AutoFocusEnable Value="0"/>
			</Preset>
			<Preset Index="2">
				<One_div_ZPS Value="0.1"/>
				<StereoBase Value="0.16"/>
				<AutoFocusEnable Value="0"/>
			</Preset>
		</Presets>

		<!-- ═══════════════ KEYBOARD HOTKEYS ══════════════════════════
			 Remap in-game hotkeys here. Key code format:
			   code = (modifier << 8) | VK_code

			 Modifiers: Shift=0x100(256), Ctrl=0x200(512), Alt=0x400(1024)
			 Common VK codes:
			   Numpad 0-9 = 96-105    Numpad * = 106    Numpad + = 107
			   Numpad - = 109         Numpad / = 111    Numpad . = 110
			   F1-F12 = 112-123       PrtScn = 44

			 Examples:
			   106 = Numpad *                    (0x00 << 8 | 0x6A)
			   363 = Shift + Numpad +            (0x01 << 8 | 0x6B)
			   631 = Ctrl + F8                   (0x02 << 8 | 0x77)

			 Set Key="0" to disable a hotkey.
			 ═══════════════════════════════════════════════════════════ -->
		<Keys>
			<!-- Numpad *: Toggle stereo 3D on/off -->
			<ToggleStereo Key="106"/>
			<!-- Shift+Numpad +: Increase convergence (push scene into screen) -->
			<ZPSIncrease Key="363"/>
			<!-- Shift+Numpad -: Decrease convergence (pull scene out of screen) -->
			<ZPSDecrease Key="365"/>
			<!-- Numpad +: Increase separation (more 3D depth) -->
			<StereoBaseIncrease Key="107"/>
			<!-- Numpad -: Decrease separation (less 3D depth) -->
			<StereoBaseDecrease Key="109"/>
			<!-- Numpad 7: Load preset 1 -->
			<SetPreset1 Key="103"/>
			<!-- Numpad 8: Load preset 2 -->
			<SetPreset2 Key="104"/>
			<!-- Numpad 9: Load preset 3 -->
			<SetPreset3 Key="105"/>
			<!-- Ctrl+F8: Swap left/right eyes -->
			<SwapEyes Key="631"/>
			<!-- Numpad /: Toggle auto-focus -->
			<ToggleAutoFocus Key="111"/>
			<!-- Ctrl+Numpad /: Toggle laser sight crosshair -->
			<ToggleLaserSight Key="623"/>
			<!-- PrintScreen: Take stereo screenshot -->
			<Screenshot Key="44"/>
			<!-- Shift+Numpad *: Open stereo wizard overlay -->
			<ToggleWizard Key="362"/>
			<!-- Disabled by default — Toggle FPS counter -->
			<ToggleFPS Key="0"/>
			<!-- Shift+F1: Toggle hotkey help OSD -->
			<ToggleHotkeysOSD Key="368"/>
			<!-- Unbound: Presenter timing adjustment (advanced perf tuning) -->
			<PresenterSleepTimeIncrease Key="0"/>
			<PresenterSleepTimeDecrease Key="0"/>
			<PresenterFlushTimeIncrease Key="0"/>
			<PresenterFlushTimeDecrease Key="0"/>
		</Keys>
	</DefaultProfile>

	<!-- ═══════════════ GPU VENDOR IDs (do not change) ═══════════════ -->
	<Vendors>
		<Vendor Name="ATI"          Value="1002" />
		<Vendor Name="AMD"          Value="1022" />
		<Vendor Name="NVidia"       Value="10DE" />
		<Vendor Name="Intel"        Value="8086" />
	</Vendors>
</Config>
