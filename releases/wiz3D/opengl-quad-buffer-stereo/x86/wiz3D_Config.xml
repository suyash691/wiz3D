<?xml version="1.0" encoding="utf-8" ?>
<!--
=============================================================================
  wiz3D Configuration — OpenGL Quad-Buffer-Stereo (x86)
=============================================================================
  Place these files in this directory next to the .exe of the game you wish
  to play. Edit values, restart the game for changes to take effect.

  This wrapper captures the game's native OpenGL quad-buffer stereo output.
=============================================================================
-->
<Config Version="1">

	<GlobalSettings>

		<!-- ───── OutputMode ────────────────────────────────────────────
		     0 = iZ3D dual-panel hardware (legacy — original iZ3D monitor)
		     1 = Half Side-by-Side    (each eye squashed to half width — works at the game's native res)
		     2 = Full Side-by-Side    (each eye at full width — set the game to half the display width)
		     3 = Half Top-and-Bottom  (each eye squashed to half height — works at native res)
		     4 = Full Top-and-Bottom  (each eye at full height — set the game to half the display height)
		     5 = Anaglyph Red/Cyan    (Dubois colour-optimized; for red/cyan glasses)
		     6 = Line Interleaved     (passive 3D TVs / row-polarised monitors)
		     7 = Column Interleaved   (rare column-polarised monitors)
		     8 = Checkerboard         (DLP-Link 3D projectors)
		     9 = Simulated Reality Weave (Samsung Odyssey 3D / Acer SpatialLabs lightfield
		                                  displays — falls back to plain Half-SBS if the
		                                  Simulated Reality runtime is not installed) -->
		<OutputMode Value="9"/>

		<!-- Swap left/right eye views: 0=normal, 1=swapped. Applies to every OutputMode. -->
		<SwapEyes Value="0"/>

		<!-- Mono-HUD overlay: experimental, currently a no-op pending a reliable
		     detection signal for "post-stereo HUD pass starts here". RtCW (and
		     other idTech 3 menu-heavy stages) draws the menu itself in 2D ortho
		     through the per-eye loop, so triggers like glOrtho /
		     glMatrixMode(PROJECTION) / glDisable(GL_DEPTH_TEST) fire during
		     right-eye rendering and we can't distinguish that from real HUD
		     setup without engine knowledge. The hook plumbing stays in place
		     so we can re-enable per-game later. Value here is read but not
		     yet acted on. -->
		<MonoHudOverlay Value="0"/>

		<!-- PFD intercept: spoof quad-buffer-stereo to games that gate on PFD_STEREO.
		     1 = yes — REQUIRED for OpenGL games like Return to Castle Wolfenstein,
		               Quake 3, Doom 3, etc. Modern consumer GPUs no longer expose
		               PFD_STEREO natively, so without this the game can't enter
		               its stereo render path at all.
		     0 = pass through (rare native quad-buffer hardware only). -->
		<EmulateQB Value="1"/>

		<!-- Anaglyph Steal: alternative stereo source for OpenGL games that
		     support anaglyph (red/cyan etc.) but NOT quad-buffer stereo, or
		     where the QBS path is buggy in the engine (e.g. ioquake3's
		     r_zProj one-eye-black issue). Turn on the game's anaglyph mode
		     (e.g. ioquake3: r_anaglyphMode 1; quake3e: r_anaglyphMode 1) and
		     pick a mode below. The wrapper hooks glColorMask, detects the
		     per-eye anaglyph mask, redirects each eye into its own PBuffer,
		     and forces the colour mask to all-true so the output is full
		     RGB instead of channel-filtered. The captured eyes drive
		     whatever OutputMode you have selected (SBS / T-B / SR / etc.) —
		     so you can play anaglyph-only games on any stereo display.
		     0 = off (default — QBS only).
		     1 = always on — every anaglyph-shaped glColorMask is treated as
		         a stereo eye marker. Use this for games that use anaglyph
		         exclusively.
		     2 = auto — engage anaglyph capture only when QBS hasn't been
		         observed in the current or previous frame. Safe for games
		         that use both modes (QBS wins) and for games that issue
		         partial colour masks for non-stereo reasons (no false
		         positive because they'd still be calling QBS DrawBuffer). -->
		<AnaglyphSteal Value="0"/>

		<!-- Wrapper enable.
		     0 = wrapper active (default)
		     2 = bypass — opengl32 proxy stays loaded but the wrapper hooks no-op,
		         useful for confirming a problem is wrapper-related vs. game-side. -->
		<RouterType Value="0"/>

		<!-- Debug log verbosity: 0=off, 1=notices, 2=trace, 3=heavy. Only takes
		     effect in non-FINAL_RELEASE builds; the shipped wrapper always emits
		     a small one-line-per-change diag file (OpenGLQuadBufferStereo.log)
		     regardless of this setting. -->
		<Trace Value="0"/>

	</GlobalSettings>

</Config>
