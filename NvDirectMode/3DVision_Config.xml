<?xml version="1.0" encoding="utf-8" ?>
<!--
  wiz3D NvDirectMode (3D Vision Direct Mode) configuration.

  Drop this file into the SAME folder as the game's executable, alongside
  the proxy DLL (d3d9.dll / d3d10.dll / d3d11.dll / opengl32.dll) and
  nvapi[64].dll. The proxy reads it on DllMain.

  If this file isn't present, the proxy uses the defaults below. Missing
  individual <Tag Value=".."/> entries also fall back to defaults — you
  can delete any line you don't want to override.
-->
<Config>
    <NvDirectMode>
        <!-- LoggingEnabled: 0 = no log file written; 1 = log lifecycle events
             (DLL load, Direct3D entry-point calls, wrapping, errors). Default: 1.
             The log lives at nvdirectmode_proxy.log next to the game exe. -->
        <LoggingEnabled Value="1"/>

        <!-- VerboseLogging: 0 = lifecycle only; 1 = per-method tracing of the
             eye-routing hot path (CreateRenderTargetView when BB-derived,
             OMSetRenderTargets eye + viewport, GetBuffer registrations,
             SwapChainProxy lifetime, Device/Context/SwapChain QI bypass
             warnings). Useful for diagnosing crashes or missing-routing
             problems; noisy.

             DEFAULT: 1 — NvDirectMode is pre-release; verbose traces help
             us diagnose game-specific issues. Switch to 0 once the game
             works and you want a quieter log. -->
        <VerboseLogging Value="1"/>

        <!-- SwapEyes: 0 = normal (LEFT eye in left half of doubled buffer);
             1 = swapped (RIGHT eye in left half). Use if your downstream
             stereo display has eyes flipped. Default: 0. -->
        <SwapEyes Value="0"/>

        <!-- WrapDevices: 0 = pure passthrough (Direct3D entry points forward
             to the real DLL unmodified, no device/context/swap-chain wrapping;
             eye routing is disabled). 1 = wrap returned objects so the proxy
             can apply per-eye RT viewport routing. Default: 1.

             KNOWN ISSUE: some games (Tomb Raider 2013, others) crash when
             our d3d11 wrapper is active because the game uses COM QueryInterface
             chains (e.g. QI for IDXGIDevice then back to ID3D11Device) that
             return real-not-wrapped objects, breaking COM identity invariants.
             Set this to 0 as a workaround — game will run mono but at least
             won't crash. A future dxgi.dll proxy will fix the underlying cause. -->
        <WrapDevices Value="1"/>

        <!-- OutputMode: how the game's per-eye render lands in the swap chain
             that gets presented. NvDirectMode's job is to route per-eye RTs
             into a side-by-side or top-and-bottom doubled surface; this option
             picks the geometry.

             0 = Half Top-and-Bottom — game runs at full resolution; each eye
                                       gets half the vertical height (stacked).
                                       Backbuffer is W x 2H.
             1 = Half Side-by-Side   — game runs at full resolution; each eye
                                       gets half the horizontal width (default).
                                       Backbuffer is 2W x H.
             2 = Full Side-by-Side   — set the game to HALF the display's
                                       horizontal resolution; each eye is
                                       output at full display width. (Same
                                       backend as mode 1; user-side res choice.)
             3 = Full Top-and-Bottom — set the game to HALF the display's
                                       vertical resolution; each eye is output
                                       at full display height. (Same backend
                                       as mode 0; user-side res choice.)
             4 = Row Interleaved     — NOT YET IMPLEMENTED, falls back to 1.
             5 = Column Interleaved  — NOT YET IMPLEMENTED, falls back to 1.
             6 = Checkerboard        — NOT YET IMPLEMENTED, falls back to 1.
             7 = Anaglyph            — NOT YET IMPLEMENTED, falls back to 1.
             8 = Simulated Reality   — NOT YET IMPLEMENTED, falls back to 1.
                                       (Will route the doubled SBS surface to
                                       the SR / LeiaSR weaver runtime.)

             Default: 1 (Half SBS) — matches the geometry NvDirectMode has
             been routing into all along. -->
        <OutputMode Value="1"/>

        <!-- DisableStereoSpoof: 0 = NvApiProxy reports stereo as enabled +
             activated (default — games see "3D Vision available" and try to
             use it); 1 = NvApiProxy reports stereo as DISABLED. Useful as a
             diagnostic to see how a game behaves when 3D Vision support is
             absent — can a game's "3D Vision" option actually toggle off?
             Does the game crash/render differently without our wrap claiming
             stereo is on?

             Read by nvapi[64].dll on DLL_PROCESS_ATTACH (same folder as the
             proxy). Default: 0. -->
        <DisableStereoSpoof Value="0"/>
    </NvDirectMode>
</Config>
