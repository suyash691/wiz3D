<?xml version="1.0" encoding="utf-8" ?>
<!--
  wiz3D NvDirectMode (3D Vision Direct Mode) configuration.

  Drop this file into the SAME folder as the game's executable, alongside
  the proxy DLL (d3d9.dll / d3d10.dll / d3d11.dll / opengl32.dll) and
  nvapi[64].dll. The proxy reads it on DllMain.

  If this file isn't present, the proxy uses the defaults below. Missing
  individual <Tag Value=".."/> entries also fall back to defaults — you
  can delete any line you don't want to override.
-->
<Config>
    <NvDirectMode>
        <!-- LoggingEnabled: 0 = no log file written; 1 = log lifecycle events
             (DLL load, Direct3D entry-point calls, wrapping, errors). Default: 1.
             The log lives at nvdirectmode_proxy.log next to the game exe. -->
        <LoggingEnabled Value="1"/>

        <!-- VerboseLogging: 0 = lifecycle only; 1 = per-method tracing of the
             eye-routing hot path (CreateRenderTargetView when BB-derived,
             OMSetRenderTargets eye + viewport, GetBuffer registrations,
             SwapChainProxy lifetime, Device/Context/SwapChain QI bypass
             warnings). Useful for diagnosing crashes or missing-routing
             problems; noisy.

             DEFAULT: 1 — NvDirectMode is pre-release; verbose traces help
             us diagnose game-specific issues. Switch to 0 once the game
             works and you want a quieter log. -->
        <VerboseLogging Value="1"/>

        <!-- SwapEyes: 0 = normal (LEFT eye in left half of doubled buffer);
             1 = swapped (RIGHT eye in left half). Use if your downstream
             stereo display has eyes flipped. Default: 0. -->
        <SwapEyes Value="0"/>

        <!-- WrapDevices: 0 = pure passthrough (Direct3D entry points forward
             to the real DLL unmodified, no device/context/swap-chain wrapping;
             eye routing is disabled). 1 = wrap returned objects so the proxy
             can apply per-eye RT viewport routing. Default: 1.

             KNOWN ISSUE: some games (Tomb Raider 2013, others) crash when
             our d3d11 wrapper is active because the game uses COM QueryInterface
             chains (e.g. QI for IDXGIDevice then back to ID3D11Device) that
             return real-not-wrapped objects, breaking COM identity invariants.
             Set this to 0 as a workaround — game will run mono but at least
             won't crash. A future dxgi.dll proxy will fix the underlying cause. -->
        <WrapDevices Value="1"/>

        <!-- OutputMode: how the game's per-eye render lands in the swap chain
             that gets presented. NvDirectMode's job is to route per-eye RTs
             into a side-by-side or top-and-bottom doubled surface; this option
             picks the geometry.

             0 = Half Top-and-Bottom — game runs at full resolution; each eye
                                       gets half the vertical height (stacked).
                                       Backbuffer is W x 2H.
             1 = Half Side-by-Side   — game runs at full resolution; each eye
                                       gets half the horizontal width (default).
                                       Backbuffer is 2W x H.
             2 = Full Side-by-Side   — set the game to HALF the display's
                                       horizontal resolution; each eye is
                                       output at full display width. (Same
                                       backend as mode 1; user-side res choice.)
             3 = Full Top-and-Bottom — set the game to HALF the display's
                                       vertical resolution; each eye is output
                                       at full display height. (Same backend
                                       as mode 0; user-side res choice.)
             4 = Row/Line Interleaved — alternating horizontal rows; passive
                                        3D TVs and FPR LG/Vizio panels.
             5 = Column Interleaved   — alternating vertical columns; rare,
                                        some old polarised monitors.
             6 = Checkerboard         — alternating pixels in a checkerboard
                                        pattern; DLP 3D projectors.
             7 = Anaglyph             — colour-filtered stereo (red/cyan etc.,
                                        works through coloured glasses on any
                                        monitor). See AnaglyphColour and
                                        AnaglyphMethod below to pick filter
                                        colour and ghosting-suppression style.
             8 = Simulated Reality    — Leia / Samsung Odyssey moving-lightfield
                                        weave. Implemented for DX11; falls back
                                        to SBS automatically on systems without
                                        the LeiaSR runtime installed (delay-load
                                        catches MOD_NOT_FOUND, ServerNot-
                                        Available exceptions, and per-game SR-
                                        incompatible exe blacklist). DX9/DX10/
                                        OpenGL: not yet wired — silently falls
                                        back to SBS. Tracking the rest in task
                                        #74 follow-ups.

             Default: 1 (Half SBS) — broadly supported, works on all stereo
             displays we've tested. Change to 8 if you have an SR/Leia/Odyssey
             3D-screen and want the weave path. -->
        <OutputMode Value="1"/>

        <!-- AnaglyphColour: glasses filter colour pair (only used when
             OutputMode=7).
             0 = Red / Cyan      — most common; widely available glasses.
             1 = Green / Magenta — alt pair; better motion fidelity.
             2 = Amber / Blue    — best colour rendition; "ColorCode 3-D" style.
             Default: 0. -->
        <AnaglyphColour Value="0"/>

        <!-- AnaglyphMethod: ghosting-vs-colour trade-off (only used when
             OutputMode=7). All seven methods come from the same coefficient
             tables wiz3D's main HD3D wrap (AmdQbProxy) ships with.
             0 = Dubois     — spectral fit; best ghosting suppression (default).
             1 = Compromise — Ahtik 2011; balanced for glasses + no glasses.
             2 = Color      — direct channel passthrough; severe colour fringing.
             3 = HalfColor  — left desaturated, right keeps colour; lower ghosting.
             4 = Optimised  — Wimmer weighted-channel; less colour than Dubois.
             5 = Grey       — both eyes greyscale; near-zero ghosting, no colour.
             6 = True       — classic single-channel luma; max ghosting, historical.
             Default: 0. -->
        <AnaglyphMethod Value="0"/>

        <!-- DisableStereoSpoof: 0 = NvApiProxy reports stereo as enabled +
             activated (default — games see "3D Vision available" and try to
             use it); 1 = NvApiProxy reports stereo as DISABLED. Useful as a
             diagnostic to see how a game behaves when 3D Vision support is
             absent — can a game's "3D Vision" option actually toggle off?
             Does the game crash/render differently without our wrap claiming
             stereo is on?

             Read by nvapi[64].dll on DLL_PROCESS_ATTACH (same folder as the
             proxy). Default: 0. -->
        <DisableStereoSpoof Value="0"/>

        <!-- UseLayoutStableProxy: D3D9 ONLY (ignored on d3d10/d3d11/opengl32).
             Tiered for games whose anti-tamper sniffs IDirect3D9 / Device
             internals.

             0 = OFF. Use the existing D3D9Proxy + Device9Proxy class wrap.
                 Default for new installs.

             1 = FACTORY-LEVEL. Hot-patch the real IDirect3D9 vtable's
                 CreateDevice / CreateDeviceEx slots and hand the GAME the
                 real IDirect3D9 (passes sniffs that walk the IDirect3D9
                 implementation looking for NVIDIA d3d9.dll signatures).
                 The DEVICE returned from CreateDevice is still our
                 Device9Proxy. Sufficient for: Hard Reset (boots, runs).
                 Insufficient for: GTA IV (passes the factory sniff but
                 crashes later inside Reset() because game's anti-tamper
                 also sniffs the device).

             2 = FACTORY + DEVICE. As level 1, plus hot-patch the real
                 IDirect3DDevice9 vtable's Reset / Present / GetBackBuffer
                 slots (and PresentEx / ResetEx for Ex devices). Game gets
                 the REAL device pointer from CreateDevice — passes any
                 sniff that walks the device's implementation. Our hooks
                 still do shadow-buffer + per-eye composite work via a
                 parallel state slot keyed by the real device pointer.
                 Use this for GTA IV.

             KNOWN LIMITATION: the vtable patches are process-global. All
             IDirect3D9 / IDirect3DDevice9 instances in the process route
             through our hooks after the first install. Single-game
             processes are the common case.

             Default 2 (factory + device) is the strictest superset and
             handles the games we've found to need this (Hard Reset, GTA
             IV). If a game later turns out to break under 2, drop to 1
             or 0 for that game. -->
        <UseLayoutStableProxy Value="2"/>
    </NvDirectMode>
</Config>
