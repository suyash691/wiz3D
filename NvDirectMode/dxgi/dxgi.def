LIBRARY dxgi
EXPORTS
    CreateDXGIFactory               @1
    CreateDXGIFactory1              @2
    CreateDXGIFactory2              @3
    DXGIDeclareAdapterRemovalSupport @4
    DXGIGetDebugInterface1          @5
    ; Cross-DLL bridge — d3d11.dll's DXGIAdapterProxy calls this when a
    ; game walks device → adapter → factory through us. Not a DXGI export.
    NvDM_DXGI_WrapFactory           @100
